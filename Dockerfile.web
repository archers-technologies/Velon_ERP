FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL=https://velonapi-production.up.railway.app
ARG VITE_PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com
ENV NODE_ENV=production \
    VERCEL=1 \
    NITRO_PRESET=node-server \
    VITE_API_URL=$VITE_API_URL \
    VITE_PUBLIC_WORKSPACE_DOMAIN=$VITE_PUBLIC_WORKSPACE_DOMAIN
RUN npm run build:web

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.output ./.output
EXPOSE 8080
CMD ["node", ".output/server/index.mjs"]
