{
  "name": "velon-erp",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:web": "npm run dev -w @velon/frontend",
    "dev:api": "npm run dev -w @velon/backend",
    "dev:all": "concurrently -n api,web -c green,blue \"npm run db:generate && npm run dev -w @velon/backend\" \"node --env-file=.env scripts/wait-for-api.mjs && npm run dev -w @velon/frontend\"",
    "build": "npm run build -w @velon/shared && npm run build -w @velon/database && npm run build -w @velon/backend && npm run build -w @velon/frontend",
    "build:web": "npm run build -w @velon/frontend",
    "build:vercel": "VERCEL=1 npm run build:web && node scripts/sync-vercel-output.mjs",
    "build:api": "npm run build -w @velon/database && npm run build -w @velon/shared && npm run build -w @velon/backend",
    "build:dev": "npm run build:dev -w @velon/frontend",
    "preview": "npm run preview -w @velon/frontend",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w @velon/frontend",
    "test:security": "npm run test:security -w @velon/backend",
    "test:unit": "npm run test:unit -w @velon/backend",
    "db:generate": "npm run generate -w @velon/database",
    "db:migrate": "npm run migrate:dev -w @velon/database",
    "db:migrate:deploy": "npm run migrate:deploy -w @velon/database",
    "db:migrate:verify": "node packages/database/scripts/verify-migrate-deploy.mjs",
    "db:seed": "npm run seed -w @velon/database",
    "db:cleanup-demo": "npm run cleanup:demo -w @velon/database",
    "db:studio": "npm run studio -w @velon/database",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "bootstrap:local": "bash scripts/bootstrap-local.sh",
    "install:stack": "bash scripts/install-stack-macos.sh",
    "verify:release": "node scripts/verify-release-readiness.mjs",
    "test:release-flow": "npm run test:e2e -w @velon/backend -- --testPathPattern=release-flow",
    "test:e2e": "npm run test:e2e -w @velon/backend",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit && npm run test:security",
    "db:backup": "bash scripts/backup-db.sh",
    "db:restore": "bash scripts/restore-db.sh",
    "db:rotate-password": "node scripts/rotate-postgres-password.mjs",
    "hosting:vercel-env": "cat .env.vercel.example",
    "hosting:railway-env": "cat .env.railway.example"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
