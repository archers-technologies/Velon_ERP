# Railway → API service → Variables
# Filled copy with your secrets: .env.railway.deploy (gitignored)
#
# Railway layout (recommended):
# - Velon_ERP service (velonerp.com): uses railway.web.json + Dockerfile.railway
#   → runs API + web together; put ALL variables below on this service.
# - Optional separate API service (railway.json): only if you do NOT use Dockerfile.railway.
#   → duplicate SMTP_*, DATABASE_URL, REDIS_URL, JWT_*, AUTH_OTP_SECRET there too.

NODE_ENV=production

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
AUTH_OTP_SECRET=

SUPER_ADMIN_EMAIL=info@velonerp.com
SUPER_ADMIN_PASSWORD=

CORS_ORIGINS=https://velonerp.com,https://www.velonerp.com,https://*.vercel.app,https://app.velonerp.com

WEB_ORIGIN=https://velonerp.com
APP_ORIGIN=https://velonerp.com
PUBLIC_APP_URL=https://velonerp.com
PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# Mail (Railway Hobby/Trial blocks outbound SMTP — use Resend)
RESEND_API_KEY=
RESEND_FROM=Velon ERP <onboarding@resend.dev>
# Optional: force SMTP instead of Resend (requires Railway Pro for outbound SMTP)
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=info@velonerp.com
# SMTP_PASS=
# SMTP_FROM=Velon ERP <info@velonerp.com>

RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

MONGODB_ENABLED=false
