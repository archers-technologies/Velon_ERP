# Railway → API service → Variables
# Paste into the dashboard or use: railway variables set KEY=value
#
# Tip: link Postgres + Redis from the API service (see docs/HOSTING.md) so
# DATABASE_URL and REDIS_URL are injected automatically — no manual copy/paste.

NODE_ENV=production

# ─── Linked services (recommended) ───────────────────────────
# After adding Postgres + Redis plugins to the same Railway project, reference them:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}
#
# Or paste the connection strings from each service's Connect tab:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@HOST.railway.internal:5432/railway
# REDIS_URL=redis://default:PASSWORD@HOST.railway.internal:6379

# ─── Secrets (generate: openssl rand -base64 48) ─────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
AUTH_OTP_SECRET=

# Super admin (used by db:seed on first deploy — store only in Railway secrets)
SUPER_ADMIN_EMAIL=info@velonerp.com
SUPER_ADMIN_PASSWORD=

# Comma-separated browser origins (no trailing slash)
CORS_ORIGINS=https://www.velonerp.com,https://velonerp.com,https://your-app.vercel.app

# Public URLs for emails and invitation links (production frontend)
WEB_ORIGIN=https://www.velonerp.com
APP_ORIGIN=https://www.velonerp.com
PUBLIC_APP_URL=https://www.velonerp.com
PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# SMTP — required in production for signup, invites, password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Velon ERP <info@velonerp.com>"

# Optional payment gateways
RAZORPAY_ENABLED=false

# MongoDB — optional secondary storage (disabled by default). See docs/MONGODB-CONFIGURATION.md
MONGODB_ENABLED=false
MONGODB_URI=
MONGODB_DATABASE=velon_erp
