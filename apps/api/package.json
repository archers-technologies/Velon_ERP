{
  "name": "@velon/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch --preserveWatchOutput --env-file ../../.env -e \"node dist/src/main.js\"",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:unit": "jest --config ./jest-unit.json --runInBand",
    "test:security": "jest --config ./test/jest-e2e.json --runInBand --forceExit --testPathPattern='(tenant-isolation|tenant-admin|tenant-reregistration|auth-signup|password-reset|auth-hardening|crm-isolation|crm-pipeline-isolation|crm-quotation-isolation|inventory-isolation|permissions|sales-order-conversion|submission-readiness|billing-razorpay)'"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/platform-socket.io": "^11.0.12",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.12",
    "@types/pdfkit": "^0.17.6",
    "@types/nodemailer": "^8.0.0",
    "@velon/database": "*",
    "@velon/shared": "*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.49.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "mongodb": "^6.16.0",
    "nodemailer": "^8.0.8",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.3",
    "@nestjs/testing": "^11.0.12",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
