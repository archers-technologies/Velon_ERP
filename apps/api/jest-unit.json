{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/../../packages/shared/src"],
  "testRegex": ".*\\.spec\\.ts$",
  "moduleNameMapper": {
    "^@velon/shared$": "<rootDir>/../../packages/shared/src/index.ts",
    "^@velon/database$": "<rootDir>/../../packages/database/src/index.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "module": "commonjs",
          "esModuleInterop": true,
          "types": ["jest", "node"]
        }
      }
    ]
  },
  "testPathIgnorePatterns": ["/node_modules/", "/dist/", ".e2e-spec.ts"]
}
