# ─── Production (Vercel + Railway) ────────────────────────────
# Frontend: https://www.velonerp.com (Vercel)
# Copy into Vercel → Environment Variables (Production + Preview):
#   VITE_API_URL=https://YOUR-RAILWAY-API.up.railway.app
#   VITE_PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com
# Copy into Railway → API service variables:
#   CORS_ORIGINS=https://www.velonerp.com,https://velonerp.com
#   WEB_ORIGIN=https://www.velonerp.com
#   APP_ORIGIN=https://www.velonerp.com
#   PUBLIC_APP_URL=https://www.velonerp.com
#   PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# ─── Web (Vite) — local dev ───────────────────────────────────
VITE_API_URL=http://localhost:3001

# Public workspace host parent domain (Super Admin tenant table)
PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com
VITE_PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# Do not seed demo tenants unless explicitly enabled locally
SEED_DEMO_DATA=false

# ─── API (NestJS) ─────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# PostgreSQL — local Docker (docker compose up -d postgres)
DATABASE_URL=postgresql://velon:velon_dev_password@127.0.0.1:5433/velon_erp?schema=public
DATABASE_URL_TEST=postgresql://velon:velon_dev_password@127.0.0.1:5433/velon_erp_test?schema=public
POSTGRES_USER=velon
POSTGRES_PASSWORD=velon_dev_password
POSTGRES_DB=velon_erp
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Redis — OTP staging, platform revision bus
REDIS_URL=redis://127.0.0.1:6379

# JWT (local dev — use strong secrets in staging/production)
JWT_ACCESS_SECRET=adc92fa52c36fc3fb87d4c2b18e38f2116060e6fbaa509b45fb7a8130f42281c
JWT_REFRESH_SECRET=2d42e5cf8c91e7a55eef8fc7d1e2721decf787aa2d5d7f83679d4d876f0b0fda
JWT_ACCESS_TTL=15m

# Super Admin seed (npm run db:seed)
SUPER_ADMIN_EMAIL=info@velonerp.com
SUPER_ADMIN_PASSWORD=tr!o@8125

# Signup email OTP (stored in Redis; delivered via SMTP in production)
AUTH_OTP_SECRET=80bd4f56ef5fdb55e147ee0d76861c5032c301eba14b04283e458c2edab857f3

WEB_ORIGIN=http://localhost:8080
APP_ORIGIN=http://localhost:8080
PUBLIC_APP_URL=http://localhost:8080

