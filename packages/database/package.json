{
  "name": "@velon/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:verify": "node scripts/verify-migrate-deploy.mjs",
    "seed": "tsx prisma/seed.ts",
    "cleanup:demo": "node scripts/cleanup-demo-data.mjs",
    "studio": "prisma studio",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@velon/shared": "*",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
