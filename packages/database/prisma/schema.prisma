generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PLATFORM_SUPPORT
  TENANT_OWNER
  TENANT_ADMIN
  DEPARTMENT_ADMIN
  USER
  TENANT_USER
}

enum TenantPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  SUSPENDED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionBillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  STC_PAY
  HYPERPAY
  BANK_TRANSFER
}

enum SubscriptionPaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum TenantHealth {
  HEALTHY
  DEGRADED
  CRITICAL
}

enum IndustryTemplate {
  RETAIL
  MANUFACTURING
  DISTRIBUTION
  SERVICES
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CrmCustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum CrmNoteTargetType {
  CUSTOMER
  CONTACT
}

enum CrmActivityType {
  CALL
  MEETING
  EMAIL
  VISIT
  TASK
  FOLLOW_UP
}

enum CrmActivityStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum CrmLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum CrmLeadSource {
  MANUAL
  WEBSITE
  REFERRAL
  EMAIL
  TRADE_SHOW
  IMPORT
  OTHER
}

enum CrmOpportunityStatus {
  OPEN
  WON
  LOST
}

enum CrmQuotationStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum CrmQuotationApprovalAction {
  SENT
  VIEWED
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  REVISION_CREATED
  COMMENT
}

enum EmailTemplateCategory {
  TRANSACTIONAL
  MARKETING
  ONBOARDING
  BILLING
  SECURITY
  SUPPORT
}

enum EmailLogStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
  SKIPPED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(USER)
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  isActive     Boolean   @default(true)
  /// null = real production user; demo | e2e | seed = excluded from Super Admin lists
  seedSource   String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens                RefreshToken[]
  memberships                  TenantMembership[]
  auditLogs                    AuditLog[]                    @relation("AuditActor")
  invitationsSent              TenantInvitation[]            @relation("InvitationInviter")
  crmCustomersCreated          CrmCustomer[]                 @relation("CrmCustomerCreatedBy")
  crmCustomersUpdated          CrmCustomer[]                 @relation("CrmCustomerUpdatedBy")
  crmContactsCreated           CrmContact[]                  @relation("CrmContactCreatedBy")
  crmContactsUpdated           CrmContact[]                  @relation("CrmContactUpdatedBy")
  crmNotesCreated              CrmNote[]                     @relation("CrmNoteCreatedBy")
  crmActivitiesCreated         CrmActivity[]                 @relation("CrmActivityCreatedBy")
  crmActivitiesUpdated         CrmActivity[]                 @relation("CrmActivityUpdatedBy")
  crmActivitiesOwned           CrmActivity[]                 @relation("CrmActivityOwner")
  crmLeadsCreated              CrmLead[]                     @relation("CrmLeadCreatedBy")
  crmLeadsAssigned             CrmLead[]                     @relation("CrmLeadAssignedTo")
  crmOpportunitiesOwned        CrmOpportunity[]              @relation("CrmOpportunityOwner")
  crmOpportunitiesCreated      CrmOpportunity[]              @relation("CrmOpportunityCreatedBy")
  crmQuotationsCreated         CrmQuotation[]                @relation("CrmQuotationCreatedBy")
  crmQuotationsApproved        CrmQuotation[]                @relation("CrmQuotationApprovedBy")
  crmProposalsGenerated        CrmProposalDocument[]         @relation("CrmProposalGeneratedBy")
  crmQuotationApprovals        CrmQuotationApprovalHistory[] @relation("CrmQuotationApprovalActor")
  crmDocumentCommentsAuthored  CrmDocumentComment[]          @relation("CrmDocumentCommentAuthor")
  companyLibraryAssetsUploaded CompanyLibraryAsset[]         @relation("CompanyLibraryAssetUploader")
  hrEmployeesManaged           HrEmployee[]                  @relation("HrEmployeeUser")
  hrEmployeesCreated           HrEmployee[]                  @relation("HrEmployeeCreatedBy")
  hrLeaveRequestsRequested     HrLeaveRequest[]              @relation("HrLeaveRequestRequester")
  hrLeaveRequestsApproved      HrLeaveRequest[]              @relation("HrLeaveRequestApprover")
  hrPayrollRunsProcessed       HrPayrollRun[]                @relation("HrPayrollRunProcessedBy")
  hrExpenseClaimsRequested     HrExpenseClaim[]              @relation("HrExpenseClaimRequester")
  hrExpenseClaimsApproved      HrExpenseClaim[]              @relation("HrExpenseClaimApprover")
  inventoryWarehousesManaged   InventoryWarehouse[]          @relation("InventoryWarehouseManager")
  inventoryProductsCreated     InventoryProduct[]            @relation("InventoryProductCreatedBy")
  purchaseRequestsRequested    PurchaseRequest[]             @relation("PurchaseRequestRequestedBy")
  purchaseRequestsApproved     PurchaseRequest[]             @relation("PurchaseRequestApprovedBy")
  purchaseOrdersApproved       PurchaseOrder[]               @relation("PurchaseOrderApprovedBy")
  supplierThreadsAuthored      SupplierThread[]              @relation("SupplierThreadAuthor")
  salesInvoicesCreated         SalesInvoice[]                @relation("SalesInvoiceCreatedBy")
  salesInvoicesUpdated         SalesInvoice[]                @relation("SalesInvoiceUpdatedBy")
  salesInvoicesSalesperson     SalesInvoice[]                @relation("SalesInvoiceSalesperson")
  salesInvoicePaymentsRecorded SalesInvoicePayment[]         @relation("SalesInvoicePaymentRecordedBy")
  emailPreferences             EmailPreference[]
  emailLogs                    EmailLog[]                    @relation("EmailLogUser")

  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Tenant {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  tenantCode        String           @unique
  country           String
  plan              TenantPlan       @default(STARTER)
  status            TenantStatus     @default(TRIAL)
  health            TenantHealth     @default(HEALTHY)
  industryTemplate  IndustryTemplate @default(SERVICES)
  usersCount        Int              @default(1)
  mrr               Decimal          @default(0) @db.Decimal(12, 2)
  storageUsedGb     Float            @default(0)
  storageCapGb      Float            @default(20)
  renewalDate       DateTime         @db.Date
  isolationVerified Boolean          @default(true)
  /// null = real tenant; demo | e2e | seed = excluded from Super Admin lists
  seedSource        String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  companyProfile                         CompanyProfile?
  workspace                              Workspace?
  memberships                            TenantMembership[]
  auditLogs                              AuditLog[]
  customers                              TenantCustomer[]
  projects                               TenantProject[]
  assets                                 TenantAsset[]
  files                                  TenantFile[]
  notifications                          Notification[]
  departments                            Department[]
  invitations                            TenantInvitation[]
  crmCustomers                           CrmCustomer[]
  crmContacts                            CrmContact[]
  crmNotes                               CrmNote[]
  crmActivities                          CrmActivity[]
  crmLeads                               CrmLead[]
  crmPipelines                           CrmPipeline[]
  crmPipelineStages                      CrmPipelineStage[]
  crmOpportunities                       CrmOpportunity[]
  crmQuotations                          CrmQuotation[]
  crmQuotationItems                      CrmQuotationItem[]
  crmProposalDocuments                   CrmProposalDocument[]
  crmProposalTemplates                   CrmProposalTemplate[]
  crmQuotationApprovals                  CrmQuotationApprovalHistory[]
  crmQuotationSequences                  CrmQuotationNumberSequence[]
  crmContentBlocks                       CrmContentBlock[]
  crmDocumentComments                    CrmDocumentComment[]
  companyLibraryAssets                   CompanyLibraryAsset[]
  hrDesignations                         HrDesignation[]
  hrEmployees                            HrEmployee[]
  hrEmployeeDocuments                    HrEmployeeDocument[]
  hrEmployeeNotes                        HrEmployeeNote[]
  hrJobOpenings                          HrJobOpening[]
  hrApplicants                           HrApplicant[]
  hrLeaveTypes                           HrLeaveType[]
  hrLeaveBalances                        HrLeaveBalance[]
  hrLeaveRequests                        HrLeaveRequest[]
  hrShifts                               HrShift[]
  hrAttendanceRecords                    HrAttendanceRecord[]
  hrHolidayCalendars                     HrHolidayCalendar[]
  hrHolidays                             HrHoliday[]
  hrSalaryComponents                     HrSalaryComponent[]
  hrSalaryStructures                     HrSalaryStructure[]
  hrSalaryStructureItems                 HrSalaryStructureItem[]
  hrPayrollRuns                          HrPayrollRun[]
  hrPayslips                             HrPayslip[]
  hrExpenseClaims                        HrExpenseClaim[]
  inventoryCategories                    InventoryCategory[]
  inventoryProducts                      InventoryProduct[]
  inventoryProductVariantAttributes      InventoryProductVariantAttribute[]
  inventoryProductVariantAttributeValues InventoryProductVariantAttributeValue[]
  inventoryProductVariants               InventoryProductVariant[]
  inventoryWarehouses                    InventoryWarehouse[]
  inventoryStock                         InventoryStock[]
  inventoryStockBatches                  InventoryStockBatch[]
  suppliers                              Supplier[]
  supplierContacts                       SupplierContact[]
  supplierThreads                        SupplierThread[]
  purchaseRequests                       PurchaseRequest[]
  purchaseRequestItems                   PurchaseRequestItem[]
  purchaseOrders                         PurchaseOrder[]
  purchaseOrderItems                     PurchaseOrderItem[]
  salesOrders                            SalesOrder[]
  salesOrderItems                        SalesOrderItem[]
  salesOrderSequences                    SalesOrderNumberSequence[]
  salesInvoices                          SalesInvoice[]
  salesInvoiceItems                      SalesInvoiceItem[]
  salesInvoicePayments                   SalesInvoicePayment[]
  salesInvoiceSequences                  SalesInvoiceNumberSequence[]
  subscription                           Subscription?

  @@index([status])
  @@index([plan])
  @@index([seedSource])
  @@index([deletedAt])
}

model PlanDefinition {
  plan                TenantPlan @id
  displayName         String
  monthlyPrice        Decimal    @db.Decimal(12, 2)
  annualPrice         Decimal    @db.Decimal(12, 2)
  currency            String     @default("INR")
  indiaMonthlyPrice   Decimal?   @db.Decimal(12, 2)
  indiaAnnualPrice    Decimal?   @db.Decimal(12, 2)
  globalMonthlyPrice  Decimal?   @db.Decimal(12, 2)
  globalAnnualPrice   Decimal?   @db.Decimal(12, 2)
  seatLimit           Int?
  storageLimitGb      Int        @default(10)
  invoiceLimitMo      Int?
  branchLimit         Int?
  trialDays           Int        @default(14)
  isEnabled           Boolean    @default(true)
  moduleHrm           Boolean    @default(true)
  moduleCrm           Boolean    @default(true)
  moduleFinance       Boolean    @default(true)
  moduleInventory     Boolean    @default(true)
  moduleManufacturing Boolean    @default(false)
  description         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model CompanyProfile {
  id          String           @id @default(cuid())
  tenantId    String           @unique
  legalName   String
  email       String
  phone       String
  country     String
  industry    IndustryTemplate
  address     String?
  website     String?
  taxId       String?
  logoDataUrl String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Workspace {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  name             String
  slug             String   @unique
  timezone         String   @default("Asia/Kolkata")
  countryCode      String   @default("IN")
  currency         String   @default("INR")
  currencySymbol   String?
  language         String   @default("en")
  dateFormat       String   @default("DD/MM/YYYY")
  numberFormat     String   @default("en-IN")
  expiringSoonDays Int      @default(30)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrders   SalesOrder[]
  salesInvoices SalesInvoice[]
}

model TenantMembership {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  departmentId String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department         Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments Department[] @relation("DepartmentManager")

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([departmentId])
}

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager       TenantMembership?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  memberships   TenantMembership[]
  invitations   TenantInvitation[]
  hrEmployees   HrEmployee[]
  hrJobOpenings HrJobOpening[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TenantInvitation {
  id           String           @id @default(cuid())
  tenantId     String
  email        String
  fullName     String
  role         UserRole         @default(USER)
  departmentId String?
  tokenHash    String           @unique
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  invitedById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  invitedBy  User        @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([tenantId, email])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  tenantId   String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor  User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([tenantId])
  @@index([action])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  title     String
  body      String
  read      Boolean  @default(false)
  channel   String   @default("in_app")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([tenantId])
  @@index([tenantId, userId])
}

model PlatformRevision {
  id        String   @id @default("main")
  revision  Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Isolation-test fixture — not a CRM module. All queries scoped by tenantId from JWT.
model TenantCustomer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Isolation-test fixture — not a project management module. Scoped by tenantId from JWT.
model TenantProject {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Isolation-test fixture — asset registry placeholder. Scoped by tenantId from JWT.
model TenantAsset {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  tag       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Isolation-test fixture — file metadata placeholder. Scoped by tenantId from JWT.
model TenantFile {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  mimeType  String   @default("application/octet-stream")
  sizeBytes Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Phase 3A CRM — tenant-scoped customer records.
model CrmCustomer {
  id           String            @id @default(cuid())
  tenantId     String
  customerCode String
  companyName  String
  legalName    String?
  industry     String?
  website      String?
  email        String?
  phone        String?
  country      String?
  city         String?
  address      String?
  taxId        String?
  notes        String?
  status       CrmCustomerStatus @default(PROSPECT)
  archivedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdById  String?
  updatedById  String?

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy      User?            @relation("CrmCustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?            @relation("CrmCustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  contacts       CrmContact[]
  activities     CrmActivity[]
  opportunities  CrmOpportunity[]
  leadsConverted CrmLead[]        @relation("CrmLeadConvertedCustomer")
  quotations     CrmQuotation[]
  salesOrders    SalesOrder[]
  salesInvoices  SalesInvoice[]

  @@unique([tenantId, customerCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, archivedAt])
}

model CrmContact {
  id          String    @id @default(cuid())
  tenantId    String
  customerId  String
  firstName   String
  lastName    String
  jobTitle    String?
  email       String?
  phone       String?
  mobile      String?
  department  String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   CrmCustomer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy  User?         @relation("CrmContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?         @relation("CrmContactUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  activities CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, archivedAt])
}

model CrmNote {
  id          String            @id @default(cuid())
  tenantId    String
  targetType  CrmNoteTargetType
  targetId    String
  content     String
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("CrmNoteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, targetType, targetId])
}

model CrmActivity {
  id           String            @id @default(cuid())
  tenantId     String
  customerId   String
  contactId    String?
  type         CrmActivityType
  title        String
  description  String?
  activityDate DateTime
  ownerId      String
  status       CrmActivityStatus @default(OPEN)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdById  String?
  updatedById  String?

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contact   CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner     User        @relation("CrmActivityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy User?       @relation("CrmActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?       @relation("CrmActivityUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, ownerId])
  @@index([tenantId, status])
  @@index([tenantId, activityDate])
}

/// Phase 3B — sales leads.
model CrmLead {
  id                     String        @id @default(cuid())
  tenantId               String
  leadCode               String
  companyName            String
  contactName            String?
  email                  String?
  phone                  String?
  source                 CrmLeadSource @default(MANUAL)
  industry               String?
  status                 CrmLeadStatus @default(NEW)
  assignedToId           String?
  notes                  String?
  archivedAt             DateTime?
  convertedCustomerId    String?
  convertedOpportunityId String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  createdById            String?

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo        User?            @relation("CrmLeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("CrmLeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  convertedCustomer CrmCustomer?     @relation("CrmLeadConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  opportunities     CrmOpportunity[]

  @@unique([tenantId, leadCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, archivedAt])
}

model CrmPipeline {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages        CrmPipelineStage[]
  opportunities CrmOpportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CrmPipelineStage {
  id          String   @id @default(cuid())
  tenantId    String
  pipelineId  String
  name        String
  position    Int
  probability Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline      CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities CrmOpportunity[]

  @@unique([tenantId, pipelineId, name])
  @@index([tenantId])
  @@index([tenantId, pipelineId])
}

model CrmOpportunity {
  id                String               @id @default(cuid())
  tenantId          String
  opportunityCode   String
  title             String
  customerId        String?
  leadId            String?
  pipelineId        String
  stageId           String
  value             Decimal              @default(0) @db.Decimal(14, 2)
  expectedCloseDate DateTime?            @db.Date
  probability       Int                  @default(0)
  ownerId           String
  description       String?
  status            CrmOpportunityStatus @default(OPEN)
  archivedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdById       String?
  updatedById       String?

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    CrmCustomer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead        CrmLead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  pipeline    CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage       CrmPipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner       User             @relation("CrmOpportunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation("CrmOpportunityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  quotations  CrmQuotation[]
  salesOrders SalesOrder[]

  @@unique([tenantId, opportunityCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, pipelineId])
  @@index([tenantId, stageId])
  @@index([tenantId, ownerId])
  @@index([tenantId, archivedAt])
}

/// Phase 3C — quotations.
model CrmQuotation {
  id                   String             @id @default(cuid())
  tenantId             String
  quotationNumber      String
  opportunityId        String?
  customerId           String
  issueDate            DateTime           @db.Date
  expiryDate           DateTime?          @db.Date
  status               CrmQuotationStatus @default(DRAFT)
  currency             String             @default("USD")
  language             String             @default("en")
  subtotal             Decimal            @default(0) @db.Decimal(14, 2)
  discount             Decimal            @default(0) @db.Decimal(14, 2)
  tax                  Decimal            @default(0) @db.Decimal(14, 2)
  total                Decimal            @default(0) @db.Decimal(14, 2)
  notes                String?
  terms                String?
  scopeOfWork          String?
  deliverables         String?
  coverTitle           String?
  executiveSummary     String?
  timeline             String?
  assumptions          String?
  exclusions           String?
  /// TipTap / section document builder payload (tenant-scoped JSON).
  documentJson         Json?
  qrCode               String?
  viewCount            Int                @default(0)
  downloadCount        Int                @default(0)
  signatureName        String?
  signatureDataUrl     String?
  signedAt             DateTime?
  revisionNumber       Int                @default(1)
  parentQuotationId    String?
  revisionReason       String?
  portalTokenHash      String?            @unique
  portalTokenExpiresAt DateTime?
  portalViewedAt       DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdById          String?
  approvedById         String?
  salesOrderId         String?            @unique

  tenant           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunity      CrmOpportunity?               @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  customer         CrmCustomer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  parentQuotation  CrmQuotation?                 @relation("CrmQuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  revisions        CrmQuotation[]                @relation("CrmQuotationRevisions")
  createdBy        User?                         @relation("CrmQuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy       User?                         @relation("CrmQuotationApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  items            CrmQuotationItem[]
  proposals        CrmProposalDocument[]
  approvalHistory  CrmQuotationApprovalHistory[]
  documentComments CrmDocumentComment[]
  salesOrder       SalesOrder?

  @@unique([tenantId, quotationNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, opportunityId])
}

model CrmQuotationItem {
  id          String   @id @default(cuid())
  tenantId    String
  quotationId String
  itemName    String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal  @default(0) @db.Decimal(14, 2)
  discount    Decimal  @default(0) @db.Decimal(14, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(14, 2)
  position    Int      @default(0)
  productId   String?
  variantId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation CrmQuotation             @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   InventoryProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant   InventoryProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, quotationId])
}

model CrmQuotationApprovalHistory {
  id          String                     @id @default(cuid())
  tenantId    String
  quotationId String
  action      CrmQuotationApprovalAction
  actorId     String?
  actorName   String?
  comments    String?
  createdAt   DateTime                   @default(now())

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation CrmQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  actor     User?        @relation("CrmQuotationApprovalActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, quotationId])
}

model CrmProposalDocument {
  id            String   @id @default(cuid())
  tenantId      String
  quotationId   String
  version       Int
  title         String?
  /// Rich proposal document sections (TipTap / builder JSON). Independent of invoice PDF.
  documentJson  Json?
  pdfContent    Bytes
  generatedAt   DateTime @default(now())
  generatedById String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation   CrmQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  generatedBy User?        @relation("CrmProposalGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, quotationId, version])
  @@index([tenantId])
  @@index([tenantId, quotationId])
}

model CrmProposalTemplate {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  description          String?
  coverTitle           String?
  scopeTemplate        String?
  deliverablesTemplate String?
  termsTemplate        String?
  /// Full reusable section layout for quotation/proposal builder.
  sectionsJson         Json?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Reusable content blocks (legal clauses, scope snippets, pricing blocks).
model CrmContentBlock {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String   @default("GENERAL")
  description String?
  contentJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, category])
}

/// Internal review comments on quotations (tenant-isolated).
model CrmDocumentComment {
  id          String   @id @default(cuid())
  tenantId    String
  quotationId String
  authorId    String?
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation CrmQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  author    User?        @relation("CrmDocumentCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, quotationId])
}

enum CompanyLibraryAssetCategory {
  COMPANY_PROFILE
  PRODUCT_CATALOG
  BROCHURE
  CERTIFICATION
  LICENSE
  CASE_STUDY
  AWARD
  PRESENTATION
  MARKETING
  OTHER
}

/// Tenant company asset library — insertable into quotations/proposals.
model CompanyLibraryAsset {
  id           String                      @id @default(cuid())
  tenantId     String
  name         String
  category     CompanyLibraryAssetCategory @default(OTHER)
  description  String?
  mimeType     String                      @default("application/octet-stream")
  fileName     String
  sizeBytes    Int                         @default(0)
  fileContent  Bytes
  contentJson  Json?
  uploadedById String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("CompanyLibraryAssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, category])
}

enum InventoryProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum InventoryUom {
  EACH
  KG
  LITER
  BOX
  CARTON
}

enum InventoryAbcClass {
  A
  B
  C
}

enum InventoryVelocity {
  FAST
  MEDIUM
  SLOW
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOID
}

enum SalesInvoicePaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  GIFT
  OTHER
}

enum SalesInvoiceLineType {
  PRODUCT
  CUSTOM
}

model InventoryCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   InventoryCategory?  @relation("InventoryCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children InventoryCategory[] @relation("InventoryCategoryTree")
  products InventoryProduct[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model InventoryProduct {
  id            String                 @id @default(cuid())
  tenantId      String
  sku           String
  name          String
  description   String?
  categoryId    String?
  uom           InventoryUom           @default(EACH)
  status        InventoryProductStatus @default(ACTIVE)
  imageDataUrl  String?
  barcode       String?
  unitPrice     Decimal                @default(0) @db.Decimal(12, 2)
  costPrice     Decimal                @default(0) @db.Decimal(12, 2)
  abcClass      InventoryAbcClass      @default(B)
  velocity      InventoryVelocity      @default(MEDIUM)
  batchTracked  Boolean                @default(false)
  variantParent String?
  hasVariants   Boolean                @default(false)
  createdById   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant               Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category             InventoryCategory?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy            User?                              @relation("InventoryProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stock                InventoryStock[]
  variantAttributes    InventoryProductVariantAttribute[]
  variants             InventoryProductVariant[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  quotationItems       CrmQuotationItem[]
  salesOrderItems      SalesOrderItem[]
  salesInvoiceItems    SalesInvoiceItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, hasVariants])
}

model InventoryProductVariantAttribute {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant                                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product InventoryProduct                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  InventoryProductVariantAttributeValue[]

  @@unique([tenantId, productId, name])
  @@index([tenantId])
  @@index([tenantId, productId])
}

model InventoryProductVariantAttributeValue {
  id          String   @id @default(cuid())
  tenantId    String
  attributeId String
  value       String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attribute InventoryProductVariantAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  options   InventoryProductVariantOption[]

  @@unique([tenantId, attributeId, value])
  @@index([tenantId])
  @@index([tenantId, attributeId])
}

model InventoryProductVariant {
  id           String                 @id @default(cuid())
  tenantId     String
  productId    String
  label        String
  sku          String
  barcode      String?
  unitPrice    Decimal                @default(0) @db.Decimal(12, 2)
  costPrice    Decimal                @default(0) @db.Decimal(12, 2)
  salePrice    Decimal?               @db.Decimal(12, 2)
  imageDataUrl String?
  status       InventoryProductStatus @default(ACTIVE)
  sortOrder    Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  tenant            Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           InventoryProduct                @relation(fields: [productId], references: [id], onDelete: Cascade)
  options           InventoryProductVariantOption[]
  stock             InventoryStock[]
  quotationItems    CrmQuotationItem[]
  salesOrderItems   SalesOrderItem[]
  salesInvoiceItems SalesInvoiceItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, status])
  @@index([tenantId, barcode])
}

model InventoryProductVariantOption {
  id               String @id @default(cuid())
  variantId        String
  attributeValueId String

  variant        InventoryProductVariant               @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue InventoryProductVariantAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
  @@index([variantId])
  @@index([attributeValueId])
}

model InventoryWarehouse {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  location    String?
  phone       String?
  email       String?
  managerName String?
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager       User?            @relation("InventoryWarehouseManager", fields: [managerId], references: [id], onDelete: SetNull)
  stock         InventoryStock[]
  salesInvoices SalesInvoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model InventoryStock {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String
  variantId    String?
  warehouseId  String
  quantity     Int      @default(0)
  reservedQty  Int      @default(0)
  minStock     Int      @default(0)
  reorderLevel Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   InventoryProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   InventoryProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse InventoryWarehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batches   InventoryStockBatch[]

  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId, warehouseId])
  @@index([tenantId, variantId, warehouseId])
}

/// Batch-level stock with manufacturing and expiry dates (FEFO).
model InventoryStockBatch {
  id          String   @id @default(cuid())
  tenantId    String
  stockId     String
  quantity    Int      @default(0)
  mfgDate     DateTime @db.Date
  expiryDate  DateTime @db.Date
  unitCost    Decimal  @default(0) @db.Decimal(12, 2)
  batchNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stock  InventoryStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, stockId])
  @@index([tenantId, expiryDate])
}

model Supplier {
  id        String         @id @default(cuid())
  tenantId  String
  code      String
  name      String
  legalName String?
  email     String?
  phone     String?
  vatNumber String?
  crNumber  String?
  country   String?
  address   String?
  status    SupplierStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts       SupplierContact[]
  purchaseOrders PurchaseOrder[]
  threads        SupplierThread[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model SupplierThread {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  authorId   String?
  authorName String
  body       String
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  author   User?    @relation("SupplierThreadAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, supplierId])
}

model SupplierContact {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  jobTitle   String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, supplierId])
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  tenantId      String
  requestNumber String
  status        PurchaseRequestStatus @default(DRAFT)
  requestedById String?
  notes         String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy User?                 @relation("PurchaseRequestRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?                 @relation("PurchaseRequestApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  items       PurchaseRequestItem[]
  orders      PurchaseOrder[]

  @@unique([tenantId, requestNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseRequestItem {
  id                 String       @id @default(cuid())
  tenantId           String
  requestId          String
  productId          String?
  description        String
  quantity           Int
  uom                InventoryUom @default(EACH)
  estimatedUnitPrice Decimal?     @db.Decimal(12, 2)
  position           Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request PurchaseRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product InventoryProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, requestId])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  poNumber     String
  supplierId   String
  requestId    String?
  status       PurchaseOrderStatus @default(DRAFT)
  subtotal     Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal             @default(0) @db.Decimal(12, 2)
  total        Decimal             @default(0) @db.Decimal(12, 2)
  notes        String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  request    PurchaseRequest?    @relation(fields: [requestId], references: [id], onDelete: SetNull)
  approvedBy User?               @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  items      PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  productId   String?
  description String
  quantity    Int
  receivedQty Int      @default(0)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(12, 2)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   PurchaseOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product InventoryProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, orderId])
}

/// Platform website CMS content blocks (hero, pricing, faq, etc.)
model SiteContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CrmQuotationNumberSequence {
  id         String @id @default(cuid())
  tenantId   String
  year       Int
  lastNumber Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@index([tenantId])
}

/// Phase 6A — sales orders from approved quotations.
model SalesOrder {
  id            String           @id @default(cuid())
  tenantId      String
  workspaceId   String
  quotationId   String?          @unique
  opportunityId String?
  customerId    String
  orderNumber   String
  status        SalesOrderStatus @default(DRAFT)
  subtotal      Decimal          @db.Decimal(12, 2)
  taxAmount     Decimal          @db.Decimal(12, 2)
  total         Decimal          @db.Decimal(12, 2)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quotation   CrmQuotation?    @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  opportunity CrmOpportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  customer    CrmCustomer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items       SalesOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, customerId])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  tenantId     String
  salesOrderId String
  productId    String?
  variantId    String?
  description  String
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  unitCost     Decimal @default(0) @db.Decimal(12, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal @db.Decimal(12, 2)
  lineTotal    Decimal @db.Decimal(12, 2)

  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder               @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    InventoryProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant    InventoryProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([salesOrderId])
}

model SalesOrderNumberSequence {
  id         String @id @default(cuid())
  tenantId   String
  year       Int
  lastNumber Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@index([tenantId])
}

/// Tenant sales invoices — persisted AR documents (distinct from POS audit tickets).
model SalesInvoice {
  id                 String                     @id @default(cuid())
  tenantId           String
  workspaceId        String
  invoiceNumber      String
  customerId         String?
  customerName       String
  customerPhone      String?
  customerEmail      String?
  customerAddress    String?
  customerTaxId      String?
  customerNotes      String?
  issueDate          DateTime                   @db.Date
  dueDate            DateTime?                  @db.Date
  status             SalesInvoiceStatus         @default(DRAFT)
  paymentMethod      SalesInvoicePaymentMethod?
  salespersonId      String?
  salespersonName    String?
  referenceNumber    String?
  notes              String?
  footerNotes        String?
  warehouseId        String?
  currency           String                     @default("INR")
  subtotal           Decimal                    @default(0) @db.Decimal(14, 2)
  discount           Decimal                    @default(0) @db.Decimal(14, 2)
  taxAmount          Decimal                    @default(0) @db.Decimal(14, 2)
  shippingCharges    Decimal                    @default(0) @db.Decimal(14, 2)
  roundingAdjustment Decimal                    @default(0) @db.Decimal(14, 2)
  total              Decimal                    @default(0) @db.Decimal(14, 2)
  amountPaid         Decimal                    @default(0) @db.Decimal(14, 2)
  balanceDue         Decimal                    @default(0) @db.Decimal(14, 2)
  stockDeductedAt    DateTime?
  idempotencyKey     String?                    @unique
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  createdById        String?
  updatedById        String?

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer    CrmCustomer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  warehouse   InventoryWarehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  salesperson User?                 @relation("SalesInvoiceSalesperson", fields: [salespersonId], references: [id], onDelete: SetNull)
  createdBy   User?                 @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                 @relation("SalesInvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items       SalesInvoiceItem[]
  payments    SalesInvoicePayment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, issueDate])
}

model SalesInvoiceItem {
  id            String               @id @default(cuid())
  tenantId      String
  invoiceId     String
  lineType      SalesInvoiceLineType @default(PRODUCT)
  productId     String?
  variantId     String?
  stockId       String?
  itemName      String
  sku           String?
  description   String?
  uom           String?
  quantity      Decimal              @default(1) @db.Decimal(12, 4)
  unitPrice     Decimal              @default(0) @db.Decimal(14, 2)
  discount      Decimal              @default(0) @db.Decimal(14, 2)
  taxRate       Decimal              @default(0) @db.Decimal(5, 2)
  taxAmount     Decimal              @default(0) @db.Decimal(14, 2)
  lineSubtotal  Decimal              @default(0) @db.Decimal(14, 2)
  lineTotal     Decimal              @default(0) @db.Decimal(14, 2)
  position      Int                  @default(0)
  stockMovement Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice SalesInvoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product InventoryProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant InventoryProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, productId])
}

model SalesInvoicePayment {
  id           String                    @id @default(cuid())
  tenantId     String
  invoiceId    String
  amount       Decimal                   @db.Decimal(14, 2)
  method       SalesInvoicePaymentMethod
  reference    String?
  notes        String?
  paidAt       DateTime                  @default(now())
  recordedById String?
  createdAt    DateTime                  @default(now())

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice    SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User?        @relation("SalesInvoicePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, invoiceId])
}

model SalesInvoiceNumberSequence {
  id         String @id @default(cuid())
  tenantId   String
  year       Int
  lastNumber Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@index([tenantId])
}

model Subscription {
  id                     String                    @id @default(cuid())
  tenantId               String                    @unique
  plan                   TenantPlan                @default(STARTER)
  billingInterval        BillingInterval           @default(MONTHLY)
  status                 SubscriptionBillingStatus @default(TRIAL)
  trialEndsAt            DateTime?                 @db.Date
  currentPeriodStart     DateTime                  @db.Date
  currentPeriodEnd       DateTime                  @db.Date
  cancelAtPeriodEnd      Boolean                   @default(false)
  cancelledAt            DateTime?
  provider               PaymentProvider?
  providerSubscriptionId String?
  mrr                    Decimal                   @default(0) @db.Decimal(12, 2)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices SubscriptionInvoice[]
  payments SubscriptionPayment[]

  @@index([status])
  @@index([currentPeriodEnd])
}

model SubscriptionInvoice {
  id                String                    @id @default(cuid())
  subscriptionId    String
  tenantId          String
  invoiceNumber     String                    @unique
  amount            Decimal                   @db.Decimal(12, 2)
  currency          String                    @default("USD")
  status            SubscriptionInvoiceStatus @default(OPEN)
  periodStart       DateTime                  @db.Date
  periodEnd         DateTime                  @db.Date
  dueDate           DateTime                  @db.Date
  paidAt            DateTime?
  providerInvoiceId String?
  createdAt         DateTime                  @default(now())

  subscription Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments     SubscriptionPayment[]

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
}

model SubscriptionPayment {
  id                String                    @id @default(cuid())
  subscriptionId    String
  tenantId          String
  invoiceId         String?
  amount            Decimal                   @db.Decimal(12, 2)
  currency          String                    @default("USD")
  status            SubscriptionPaymentStatus @default(PENDING)
  provider          PaymentProvider
  providerPaymentId String?
  providerOrderId   String?
  idempotencyKey    String?                   @unique
  metadata          Json?
  approvedBy        String?
  approvedAt        DateTime?
  verifiedAt        DateTime?
  failureReason     String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  subscription Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice      SubscriptionInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@unique([provider, providerOrderId])
  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
}

model BillingWebhookEvent {
  id              String          @id @default(cuid())
  provider        PaymentProvider
  providerEventId String?         @unique
  eventType       String
  payload         Json
  processed       Boolean         @default(false)
  processedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([provider, processed])
  @@index([createdAt])
}

/// CRM email lifecycle — templates, logs, preferences, and domain events.
model EmailTemplate {
  id          String                @id @default(cuid())
  key         String                @unique
  name        String
  category    EmailTemplateCategory
  subject     String
  previewText String?
  htmlBody    String                @db.Text
  textBody    String                @db.Text
  isActive    Boolean               @default(true)
  version     Int                   @default(1)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model EmailLog {
  id                String         @id @default(cuid())
  tenantId          String?
  userId            String?
  customerId        String?
  invoiceId         String?
  paymentId         String?
  subscriptionId    String?
  templateKey       String
  idempotencyKey    String?        @unique
  toEmail           String
  fromEmail         String
  subject           String
  status            EmailLogStatus @default(QUEUED)
  provider          String?
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime       @default(now())

  user User? @relation("EmailLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([customerId])
  @@index([templateKey])
  @@index([status])
  @@index([createdAt])
}

model EmailPreference {
  id                         String    @id @default(cuid())
  userId                     String
  tenantId                   String?
  transactionalEnabled       Boolean   @default(true)
  billingAlertsEnabled       Boolean   @default(true)
  securityAlertsEnabled      Boolean   @default(true)
  productUpdatesOptIn        Boolean   @default(false)
  marketingOptIn             Boolean   @default(false)
  trainingAnnouncementsOptIn Boolean   @default(false)
  preferenceToken            String    @unique @default(cuid())
  unsubscribedAt             DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
}

model EmailEvent {
  id          String    @id @default(cuid())
  eventType   String
  entityType  String
  entityId    String
  tenantId    String?
  payloadJson Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([eventType, entityId])
  @@index([processedAt])
  @@index([tenantId])
}

// ─── HRMS & Payroll (tenant-isolated, country-agnostic core) ───

enum HrEmploymentStatus {
  ACTIVE
  PROBATION
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum HrLeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HrAttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  WEEKEND
}

enum HrPayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED
}

enum HrSalaryComponentType {
  EARNING
  DEDUCTION
  EMPLOYER_CONTRIBUTION
}

enum HrExpenseClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

enum HrApplicantStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum HrJobOpeningStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

model HrDesignation {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  level       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees HrEmployee[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model HrEmployee {
  id                String             @id @default(cuid())
  tenantId          String
  employeeCode      String
  firstName         String
  lastName          String
  email             String?
  phone             String?
  dateOfBirth       DateTime?          @db.Date
  hireDate          DateTime           @db.Date
  probationEndDate  DateTime?          @db.Date
  terminationDate   DateTime?          @db.Date
  status            HrEmploymentStatus @default(ACTIVE)
  departmentId      String?
  designationId     String?
  managerId         String?
  userId            String?
  branchName        String?
  workLocation      String?
  currency          String             @default("USD")
  baseSalary        Decimal            @default(0) @db.Decimal(14, 2)
  salaryStructureId String?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  notes             String?
  createdById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation     HrDesignation?       @relation(fields: [designationId], references: [id], onDelete: SetNull)
  manager         HrEmployee?          @relation("HrEmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports   HrEmployee[]         @relation("HrEmployeeManager")
  user            User?                @relation("HrEmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  createdBy       User?                @relation("HrEmployeeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  salaryStructure HrSalaryStructure?   @relation(fields: [salaryStructureId], references: [id], onDelete: SetNull)
  documents       HrEmployeeDocument[]
  employeeNotes   HrEmployeeNote[]
  leaveBalances   HrLeaveBalance[]
  leaveRequests   HrLeaveRequest[]
  attendance      HrAttendanceRecord[]
  payslips        HrPayslip[]
  expenseClaims   HrExpenseClaim[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, managerId])
}

model HrEmployeeDocument {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  name        String
  category    String    @default("GENERAL")
  mimeType    String    @default("application/octet-stream")
  fileName    String
  sizeBytes   Int       @default(0)
  fileContent Bytes
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
}

model HrEmployeeNote {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
}

model HrJobOpening {
  id           String             @id @default(cuid())
  tenantId     String
  title        String
  departmentId String?
  description  String?
  location     String?
  status       HrJobOpeningStatus @default(DRAFT)
  openings     Int                @default(1)
  publishedAt  DateTime?
  closedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  applicants HrApplicant[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model HrApplicant {
  id           String            @id @default(cuid())
  tenantId     String
  jobOpeningId String
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeText   String?
  resumeMime   String?
  resumeFile   Bytes?
  status       HrApplicantStatus @default(NEW)
  score        Int?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobOpening HrJobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, jobOpeningId])
  @@index([tenantId, status])
}

model HrLeaveType {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  code            String
  paid            Boolean  @default(true)
  annualAllowance Decimal  @default(0) @db.Decimal(8, 2)
  accrualEnabled  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balances HrLeaveBalance[]
  requests HrLeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model HrLeaveBalance {
  id          String  @id @default(cuid())
  tenantId    String
  employeeId  String
  leaveTypeId String
  year        Int
  entitled    Decimal @default(0) @db.Decimal(8, 2)
  used        Decimal @default(0) @db.Decimal(8, 2)
  pending     Decimal @default(0) @db.Decimal(8, 2)

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  HrEmployee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType HrLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, leaveTypeId, year])
  @@index([tenantId])
}

model HrLeaveRequest {
  id            String               @id @default(cuid())
  tenantId      String
  employeeId    String
  leaveTypeId   String
  startDate     DateTime             @db.Date
  endDate       DateTime             @db.Date
  days          Decimal              @db.Decimal(8, 2)
  reason        String?
  status        HrLeaveRequestStatus @default(PENDING)
  requestedById String?
  approvedById  String?
  decidedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    HrEmployee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   HrLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  requestedBy User?       @relation("HrLeaveRequestRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?       @relation("HrLeaveRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

model HrShift {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  startTime String
  endTime   String
  breakMins Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendance HrAttendanceRecord[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model HrAttendanceRecord {
  id           String             @id @default(cuid())
  tenantId     String
  employeeId   String
  workDate     DateTime           @db.Date
  checkInAt    DateTime?
  checkOutAt   DateTime?
  shiftId      String?
  status       HrAttendanceStatus @default(PRESENT)
  overtimeMins Int                @default(0)
  latitude     Float?
  longitude    Float?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    HrShift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@unique([tenantId, employeeId, workDate])
  @@index([tenantId])
  @@index([tenantId, workDate])
}

model HrHolidayCalendar {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  holidays HrHoliday[]

  @@unique([tenantId, name, year])
  @@index([tenantId])
}

model HrHoliday {
  id          String   @id @default(cuid())
  tenantId    String
  calendarId  String
  name        String
  holidayDate DateTime @db.Date
  createdAt   DateTime @default(now())

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendar HrHolidayCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, calendarId])
}

model HrSalaryComponent {
  id        String                @id @default(cuid())
  tenantId  String
  name      String
  code      String
  type      HrSalaryComponentType
  taxable   Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  HrSalaryStructureItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model HrSalaryStructure {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  currency    String   @default("USD")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     HrSalaryStructureItem[]
  employees HrEmployee[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model HrSalaryStructureItem {
  id          String   @id @default(cuid())
  tenantId    String
  structureId String
  componentId String
  amount      Decimal  @default(0) @db.Decimal(14, 2)
  percentage  Decimal? @db.Decimal(8, 2)
  formula     String?

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  structure HrSalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  component HrSalaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, structureId, componentId])
  @@index([tenantId])
}

model HrPayrollRun {
  id            String             @id @default(cuid())
  tenantId      String
  name          String
  periodStart   DateTime           @db.Date
  periodEnd     DateTime           @db.Date
  status        HrPayrollRunStatus @default(DRAFT)
  currency      String             @default("USD")
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  processedBy User?       @relation("HrPayrollRunProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  payslips    HrPayslip[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model HrPayslip {
  id           String   @id @default(cuid())
  tenantId     String
  payrollRunId String
  employeeId   String
  grossPay     Decimal  @default(0) @db.Decimal(14, 2)
  deductions   Decimal  @default(0) @db.Decimal(14, 2)
  netPay       Decimal  @default(0) @db.Decimal(14, 2)
  currency     String   @default("USD")
  linesJson    Json?
  pdfContent   Bytes?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun HrPayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   HrEmployee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, payrollRunId, employeeId])
  @@index([tenantId])
  @@index([tenantId, employeeId])
}

model HrExpenseClaim {
  id            String               @id @default(cuid())
  tenantId      String
  employeeId    String
  title         String
  amount        Decimal              @db.Decimal(14, 2)
  currency      String               @default("USD")
  status        HrExpenseClaimStatus @default(DRAFT)
  receiptMime   String?
  receiptFile   Bytes?
  notes         String?
  requestedById String?
  approvedById  String?
  decidedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestedBy User?      @relation("HrExpenseClaimRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?      @relation("HrExpenseClaimApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}
