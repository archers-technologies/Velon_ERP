# Copy to .env and fill secrets. Never commit .env.

NODE_ENV=development

# Local stack (Homebrew postgresql@16 on :5433 + redis, or docker compose)
DATABASE_URL=postgresql://velon:velon_dev_password@127.0.0.1:5433/velon_erp?schema=public
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
AUTH_OTP_SECRET=change-me-otp-secret-min-32-chars-long

SUPER_ADMIN_EMAIL=info@velonerp.com
SUPER_ADMIN_PASSWORD=

# Workspace login for local testing (npm run db:seed after setting password)
DEV_TENANT_EMAIL=tenant@velonerp.com
DEV_TENANT_PASSWORD=
DEV_TENANT_COMPANY_NAME=Velon Test Workspace

CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

WEB_ORIGIN=http://localhost:8080
APP_ORIGIN=http://localhost:8080
PUBLIC_APP_URL=http://localhost:8080
PUBLIC_WORKSPACE_DOMAIN=localhost

API_PORT=3001
API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_PUBLIC_WORKSPACE_DOMAIN=localhost

# Mail — required for login alerts, password reset, and lifecycle emails
# Recommended for Railway: Resend (Hobby/Trial blocks outbound SMTP)
# RESEND_API_KEY=
# RESEND_FROM=Velon ERP <onboarding@resend.dev>
# Or local/production SMTP:
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Velon ERP <noreply@example.com>
# APP_BASE_URL=http://localhost:8080
# SUPPORT_EMAIL=support@example.com

SEED_DEMO_DATA=false
VELON_SEED_DEMO_TENANTS=false

# MONGODB_ENABLED=false
# RAZORPAY_ENABLED=false
