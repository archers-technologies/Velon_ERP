# Local setup: cp .env.example .env → npm run install:stack (macOS/Homebrew) or npm run bootstrap:local (Docker)
#
# Hosting (Vercel + Railway): see docs/HOSTING.md
#   Vercel copy-paste → .env.vercel.example
#   Railway copy-paste → .env.railway.example
#   Change local DB password → npm run db:rotate-password -- 'new-password'
#
# ─── Web (Vite) ───────────────────────────────────────────────
# Required — browser calls to the NestJS API. Local dev: http://localhost:3001
VITE_API_URL=http://localhost:3001

# Public marketing / app origin (invitation links, customer portals). Local dev: http://localhost:8080
WEB_ORIGIN=http://localhost:8080
# Alias used by some API email templates
APP_ORIGIN=http://localhost:8080
PUBLIC_APP_URL=http://localhost:8080

# Public workspace subdomain parent domain (Super Admin tenant table, provisioning previews)
# Example host: sah-digitals.app.velonerp.com
PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com
VITE_PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# ─── API (NestJS) ─────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development

# Comma-separated browser origins allowed by CORS (include all Vercel/preview domains in production)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# PostgreSQL — required. System of record for tenants, ERP modules, billing, audit.
# Docker Compose: port 5432. Homebrew postgresql@16 on macOS: often 5433.
DATABASE_URL=postgresql://velon:velon_dev_password@127.0.0.1:5432/velon_erp?schema=public

# Redis — required for OTP staging, session helpers, platform sync bus.
REDIS_URL=redis://127.0.0.1:6379

# MongoDB — optional secondary storage (disabled by default). PostgreSQL remains the ERP system of record.
# See docs/MONGODB-CONFIGURATION.md. Local container: docker compose --profile mongo up -d
MONGODB_ENABLED=false
MONGODB_URI=
MONGODB_DATABASE=velon_erp

# JWT — required. Generate strong secrets for staging/production (openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m

# Super Admin seed — required for `npm run db:seed` (never commit real values in .env)
SUPER_ADMIN_EMAIL=info@velonerp.com
SUPER_ADMIN_PASSWORD=

# Signup / password-reset OTP — required. Stored in Redis; delivered via SMTP in production.
AUTH_OTP_SECRET=change-me-otp-secret-min-32-chars

# SMTP — required in production for signup, invites, and password reset emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Velon ERP <info@velonerp.com>"

# SSO provider entry URLs — leave empty until Google/Microsoft OAuth is configured.
VITE_MICROSOFT_SSO_URL=
VITE_GOOGLE_SSO_URL=

# Optional: seed demo tenants in development only (never in production)
# Set SEED_DEMO_DATA=true locally to create Demo Retail Co. when the tenant table is empty.
SEED_DEMO_DATA=false
VELON_SEED_DEMO_TENANTS=false

# Optional: separate database for e2e tests (defaults to DATABASE_URL with _test suffix)
# DATABASE_URL_TEST=postgresql://velon:velon_dev_password@127.0.0.1:5433/velon_erp_test?schema=public

# Remove demo/e2e rows from an existing dev database:
# npm run db:cleanup-demo

# After schema changes, deploy migrations before starting the API:
#   npm run db:generate && npm run db:migrate:deploy
# Verify with: npm run verify:release

# S3-compatible object storage — required when file uploads are enabled.
S3_ENDPOINT=
S3_BUCKET=velon-erp
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# Payment gateways — only set when a gateway is fully wired end-to-end.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Razorpay (India) — set RAZORPAY_ENABLED=true only when all keys are configured.
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
# Optional USD→INR conversion for plan list prices (default 83)
# RAZORPAY_USD_INR_RATE=83
