# Copy these into Vercel → Project → Settings → Environment Variables
# Safe for the browser — never put JWT, DATABASE_URL, or SMTP secrets here.
#
# vercel.json already sets buildCommand, outputDirectory, and SPA rewrites.
# Import this repo at the root; no framework preset changes needed.

# Production + Preview (point both at your Railway API public URL)
VITE_API_URL=https://your-api.up.railway.app

# Public workspace subdomain parent (marketing + tenant host previews)
VITE_PUBLIC_WORKSPACE_DOMAIN=app.velonerp.com

# Optional SSO entry URLs (leave empty until OAuth is configured)
# VITE_MICROSOFT_SSO_URL=
# VITE_GOOGLE_SSO_URL=
