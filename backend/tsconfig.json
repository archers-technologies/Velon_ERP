{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "paths": {
      "@velon/database": ["../packages/database/dist/index"],
      "@velon/shared": ["../packages/shared-kernel/dist/index"],
      "@velon/shared/signup-verification": ["../packages/shared-kernel/dist/signup-verification"],
      "@velon/shared/password-reset-verification": [
        "../packages/shared-kernel/dist/password-reset-verification"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.spec.ts"]
}
