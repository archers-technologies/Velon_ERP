{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile.api"
  },
  "deploy": {
    "preDeployCommand": "node packages/database/scripts/require-database-url.mjs && cd packages/database && npx prisma migrate deploy",
    "startCommand": "node /backend/dist/main.js",
    "healthcheckPath": "/api/v1/health/live",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
